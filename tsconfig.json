{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "target": "es2021",
    "sourceMap": true,
    "baseUrl": "./",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0",
    "newLine": "lf",
    "types": [
      "jest",
      "node",
      "express"
    ]
  },
  "include": [
    "**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
