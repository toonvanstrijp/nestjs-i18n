{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "import"
  ],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "dist/*",
    "coverage/*",
    "docs/*",
    "tests/*",
  ],
  "rules": {
    "no-explicit-any": "off",
    "no-unused-vars": [
      "error",
      {
        "fix": {
          "imports": "safe-fix",
          "variables": "off"
        }
      }
    ]
  },
  "env": {
    "builtin": true
  }
}
